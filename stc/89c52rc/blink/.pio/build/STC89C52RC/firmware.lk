-muwx
-i .pio/build/STC89C52RC/firmware.hex
-M
-I 0x0100
-X 0x0100
-C 0x2000
-b HOME = 0x0000
-b XSEG = 0x0001
-b PSEG = 0x0001
-b ISEG = 0x0000
-b BSEG = 0x0000
-k .pio/build/STC89C52RC
-k /home/mkhuthir/.platformio/packages/toolchain-sdcc/bin/../share/sdcc/lib/small
-k /usr/local/share/sdcc/lib/small
-l mcs51
-l libsdcc
-l libint
-l liblong
-l libfloat
.pio/build/STC89C52RC/src/delay.rel
.pio/build/STC89C52RC/src/main.rel

-e
